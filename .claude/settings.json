{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Read",
      "Glob",
      "Grep",
      "Read(//home/vscode/.cache/uv/**)",
      "Bash(sudo -n true)",
      "Skill(update-config)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:fonts.googleapis.com)",
      "Bash(npm pkg *)",
      "Bash(DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db npm run *)",
      "Skill(commit-commands:commit-push-pr)",
      "WebFetch(domain:cli.github.com)"
    ],
    "deny": [],
    "defaultMode": "auto",
     "autoMode": {
      "environment": [
        "$defaults",
        "Source control: github.com/jasper-trustworks and all repos under it are trusted; pushing the project's source there is authorized"
      ]
    }
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "/workspace",
        "/tmp",
        "~/.npm",
        "~/.m2",
        "~/.bun",
        "~/.nuget",
        "~/.cache",
        "~/.local",
        "~/.config",
        "~/.gitconfig",
        "~/.claude"
      ]
    },
    "excludedCommands": [
      "docker",
      "docker-compose"
    ]
  },
  "extraKnownMarketplaces": {
    "gitnexus-tools": {
      "source": {
        "source": "settings",
        "name": "gitnexus-tools",
        "plugins": [
          {
            "name": "gitnexus",
            "source": {
              "source": "url",
              "url": "https://github.com/abhigyanpatwari/GitNexus.git",
              "path": "gitnexus-claude-plugin"
            }
          }
        ]
      }
    },
    "trustworks-plugins": {
      "source": {
        "source": "directory",
        "path": "/opt/claude-seed/marketplaces/trustworks-plugins"
      }
    }
  },
  "enabledPlugins": {
    "caveman@trustworks-plugins": true,
    "socratic-ideation@trustworks-plugins": true,
    "tw-claude-skills@trustworks-plugins": true,
    "gitnexus@gitnexus-tools": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "spec-lite@trustworks-plugins": true,
    "typescript-lsp@claude-plugins-official": true,
    "tw-code-review@trustworks-plugins": true,
    "devcontainer-generator@trustworks-plugins": true
  },
  "skillOverrides": {
    "code-review": "user-invocable-only",
    "review": "user-invocable-only",
    "fewer-permission-prompts": "user-invocable-only",
    "verify": "user-invocable-only"
  },
  "outputStyle": "default",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "export PATH=\"$HOME/.local/bin:$PATH\"; command -v agr >/dev/null 2>&1 && agr sync >/dev/null 2>&1 || true",
            "timeout": 120,
            "statusMessage": "Syncing agent skills (agr sync)…"
          }
        ]
      }
    ]
  }
}
