# Git worktrees (created locally by `git worktree add`)
.worktrees/

# DevContainer — plugin marketplace repos (content baked into image, git history not needed)
.devcontainer/.plugin-marketplace/

# DevContainer — per-developer git identity (gitignored; copy from .env.local.example)
.devcontainer/.env.local

# agr — skills fetched on demand by the SessionStart `agr sync` hook (declared in
# agr.toml, pinned by agr.lock); not vendored into the repo
.claude/skills/

# Claude — SessionStart agr-sync diagnostics log (runtime output, not source)
.claude/logs/

# Claude — git worktrees created by EnterWorktree (live under the bind mount so
# they persist + stay sandbox-writable; never committed to the main tree)
.claude/worktrees/

# Next.js
.next/
out/
node_modules/
next-env.d.ts

# Test coverage
src/coverage/

# Playwright
/playwright-report/
/test-results/
/e2e-results/

# TypeScript build cache
*.tsbuildinfo

# env files
.env
.env*.local

# Vercel
.vercel
.claude/settings.local.json
