# Per-developer devcontainer environment.
# Copy this file to `.env.local` (same directory) and fill in your values.
# `.env.local` is gitignored and sourced by post-create.sh on container creation.

# Git identity — used by post-create.sh to run `git config --global`.
export GIT_USER_NAME="Your Name"
export GIT_USER_EMAIL="you@example.com"
