{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Read",
      "Glob",
      "Grep",
      "Read(//home/vscode/.cache/uv/**)",
      "Bash(sudo -n true)",
      "Skill(update-config)"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "/workspace",
        "/tmp",
        "~/.npm",
        "~/.m2",
        "~/.bun",
        "~/.nuget",
        "~/.cache",
        "~/.local",
        "~/.config",
        "~/.gitconfig",
        "~/.claude"
      ]
    },
    "excludedCommands": [
      "docker",
      "docker-compose"
    ]
  },
  "extraKnownMarketplaces": {
    "gitnexus-tools": {
      "source": {
        "source": "settings",
        "name": "gitnexus-tools",
        "plugins": [
          {
            "name": "gitnexus",
            "source": {
              "source": "url",
              "url": "https://github.com/abhigyanpatwari/GitNexus.git",
              "path": "gitnexus-claude-plugin"
            }
          }
        ]
      }
    },
    "trustworks-plugins": {
      "source": {
        "source": "directory",
        "path": "/opt/claude-seed/marketplaces/trustworks-plugins"
      }
    }
  },
  "enabledPlugins": {
    "arch@trustworks-plugins": true,
    "caveman@trustworks-plugins": true,
    "socratic-ideation@trustworks-plugins": true,
    "tw-claude-skills@trustworks-plugins": true,
    "gitnexus@gitnexus-tools": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "spec-lite@trustworks-plugins": true,
    "typescript-lsp@claude-plugins-official": true,
    "tw-code-review@trustworks-plugins": true,
    "devcontainer-generator@trustworks-plugins": true
  },
  "skillOverrides": {
    "code-review": "user-invocable-only",
    "review": "user-invocable-only",
    "fewer-permission-prompts": "user-invocable-only",
    "verify": "user-invocable-only"
  },
  "outputStyle": "default",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "export PATH=\"$HOME/.local/bin:$PATH\"; command -v agr >/dev/null 2>&1 && agr sync >/dev/null 2>&1 || true",
            "timeout": 120,
            "statusMessage": "Syncing agent skills (agr sync)…"
          }
        ]
      }
    ]
  }
}
